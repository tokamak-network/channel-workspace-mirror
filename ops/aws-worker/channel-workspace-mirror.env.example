DATABASE_URL=postgresql://...
BLOB_READ_WRITE_TOKEN=...
ADMIN_TOKEN=...

# Optional. The bootstrap script uses this when cloning the app on a fresh EC2 host.
APP_REPO_URL=https://github.com/<owner>/<repo>.git

# Optional. Defaults are suitable for the current worker.
APP_BRANCH=main
NODE_MAJOR=22
PRIVATE_STATE_CLI_VERSION=latest
